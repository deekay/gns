# Quickest path: run the self-hosted stack against the bundled fixture chain.
# This gives you a working local resolver + website with no external dependencies.
GNS_SOURCE_MODE=fixture
GNS_FIXTURE_PATH=fixtures/demo-chain.json
GNS_EXPECT_CHAIN=signet
GNS_WEB_NETWORK_LABEL=Self-Hosted Fixture Demo
GNS_WEB_SHOW_LIVE_SMOKE=false
GNS_WEB_PRIVATE_SIGNET_FUNDING_ENABLED=false

# Host bindings
GNS_WEB_BIND=127.0.0.1
GNS_WEB_PORT=3000
GNS_RESOLVER_BIND=127.0.0.1
GNS_RESOLVER_PORT=8787

# Optional path prefix for reverse proxies
GNS_WEB_BASE_PATH=

# Optional polling interval for live chain modes
GNS_RPC_POLL_INTERVAL_MS=10000

# To switch to your own Bitcoin Core node, replace the fixture settings above with:
# GNS_SOURCE_MODE=rpc
# GNS_EXPECT_CHAIN=signet
# GNS_BITCOIN_RPC_URL=http://host.docker.internal:38332
# GNS_BITCOIN_RPC_USERNAME=gnsrpc
# GNS_BITCOIN_RPC_PASSWORD=replace-me
# GNS_WEB_NETWORK_LABEL=Self-Hosted Signet

# To switch to an Esplora backend instead:
# GNS_SOURCE_MODE=esplora
# GNS_EXPECT_CHAIN=signet
# GNS_ESPLORA_BASE_URL=https://blockstream.info/signet/api
# GNS_WEB_NETWORK_LABEL=Self-Hosted Signet (Esplora)
