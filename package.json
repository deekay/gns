{
  "name": "ont",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run test",
    "bootstrap:vps": "bash ./scripts/bootstrap-vps.sh",
    "bootstrap:ont-domain:vps": "bash ./scripts/bootstrap-ont-domain.sh",
    "bootstrap:private-signet:vps": "bash ./scripts/bootstrap-private-signet-vps.sh",
    "dev:all": "concurrently -k -n resolver,web -c auto \"npm run dev:resolver\" \"npm run dev:web\"",
    "dev:cli": "npm run dev -w @ont/cli --",
    "dev:indexer": "npm run dev -w @ont/indexer",
    "dev:resolver": "npm run dev -w @ont/resolver",
    "dev:web": "npm run dev -w @ont/web",
    "deploy:vps": "bash ./scripts/deploy-vps.sh",
    "deploy:private-signet:vps": "bash ./scripts/deploy-private-signet-vps.sh",
    "sparrow:private-signet:config": "bash ./scripts/print-private-signet-sparrow-config.sh",
    "sparrow:private-signet:configure": "bash ./scripts/configure-sparrow-private-signet.sh",
    "sparrow:private-signet:start": "bash ./scripts/start-private-signet-sparrow-session.sh",
    "sparrow:private-signet:tunnel": "bash ./scripts/open-private-signet-sparrow-tunnel.sh",
    "reset:private-signet-demo": "bash ./scripts/reset-private-signet-demo.sh",
    "reseed:private-signet:canonical": "bash ./scripts/reseed-private-signet-canonical.sh",
    "reseed:private-signet-demo": "node ./scripts/private-signet-reseed-demo.mjs",
    "selfhost:init": "bash ./scripts/selfhost-init.sh",
    "selfhost:doctor": "bash ./scripts/selfhost-doctor.sh",
    "selfhost:down": "docker compose down",
    "selfhost:indexer": "docker compose run --rm indexer",
    "selfhost:reset": "docker compose down -v",
    "selfhost:up": "docker compose up --build",
    "test:private-signet-batch-smoke": "node ./scripts/private-signet-batch-smoke.mjs",
    "test:private-signet-auction-smoke": "node ./scripts/private-signet-auction-smoke.mjs",
    "test:private-signet-auction-phase-gallery": "node ./scripts/private-signet-auction-phase-gallery.mjs",
    "test:private-signet-claim-smoke": "node ./scripts/private-signet-claim-smoke.mjs",
    "test:private-signet-demo": "node ./scripts/private-signet-demo.mjs",
    "test:private-signet-transfer-smoke": "node ./scripts/private-signet-transfer-smoke.mjs",
    "test:private-signet-value-handoff-smoke": "node ./scripts/private-signet-value-handoff-smoke.mjs",
    "playwright:install": "playwright install chromium",
    "review:refresh": "bash ./scripts/review-refresh.sh",
    "review:refresh:local": "ONT_REVIEW_REFRESH_SKIP_PRIVATE_SIGNET=1 ONT_REVIEW_REFRESH_SKIP_REGTEST=1 bash ./scripts/review-refresh.sh",
    "test:regtest-cli-suite": "node ./scripts/regtest-cli-suite.mjs",
    "test": "npm run build && npm run test:workspaces",
    "test:e2e:fixture-web": "node ./scripts/e2e-fixture-web.mjs",
    "test:smoke-fixture-batch": "node ./scripts/smoke-fixture-batch.mjs",
    "test:smoke-fixture": "node ./scripts/smoke-fixture.mjs",
    "measure:batch-footprint": "npm run build -w @ont/protocol && npm run build -w @ont/architect && node ./scripts/measure-batch-footprint.mjs",
    "measure:annex-hybrid-model": "npm run build -w @ont/protocol && npm run build -w @ont/architect && node ./scripts/measure-annex-hybrid-model.mjs",
    "spike:annex-keypath-reveal": "node ./scripts/spike-annex-keypath-reveal.mjs",
    "spike:annex-artifact-roundtrip": "node ./scripts/spike-annex-artifact-roundtrip.mjs",
    "test:workspaces": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "concurrently": "^9.2.1",
    "playwright": "^1.59.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
